# Copy this file to `.env` in the repo root and set your own values.
# Docker Compose loads `.env` automatically. The real `.env` is gitignored.
#
# Local dev defaults match the previous hardcoded values. For anything
# shared or deployed, use strong unique passwords and a proper secret store.

# Bitnami PostgreSQL: superuser (used as Username=postgres in connection strings)
POSTGRESQL_PASSWORD=postgres

# Replication user (master + slave must match)
POSTGRESQL_REPLICATION_USER=replicator
POSTGRESQL_REPLICATION_PASSWORD=replicator_pass

# Application database name (must match connection strings in api-node services)
POSTGRESQL_DATABASE=products_db
